[run]
# ── Scope ─────────────────────────────────────────────────────────────────────
# Only measure coverage inside the apps/ package — the real backend logic.
source = .

# Track branch coverage for accurate condition-path analysis.
branch = true

# Respect .coveragerc even when called via pytest-cov.
relative_files = true

# ── Omit ──────────────────────────────────────────────────────────────────────
# Exclude every file that is NOT production backend logic.
omit =
    # ── Django / framework boilerplate ────────────────────────────────────────
    */manage.py
    */conftest.py
    */wsgi.py
    */asgi.py
    */config/settings*.py
    */config/celery.py
    */config/notifications.py
    */config/urls.py
    */config/__init__.py

    # ── Database migrations (auto-generated, never hand-written logic) ─────────
    */migrations/*

    # ── Simulation & one-off scripts (not shipped to production) ──────────────
    */simulate_tracking.py
    */simulate_3_drivers.py
    */simulate_live_map.py
    */scripts/simulate_ride_fare.py
    */scripts/*

    # ── Debug / maintenance utilities (run manually by eng, not by the app) ───
    */fix_drift.py
    */fix_db.py
    */fix2.py
    */fix3.py
    */fix4.py
    */fix_duplicates.py
    */inspect_db.py
    */diag.py
    */cancel_ride_47.py
    */reset_fleet.py
    */FIX_GOOGLE_API_KEY.py

    # ── Seed / admin-setup scripts ─────────────────────────────────────────────
    */create_admin_user.py
    */seed_offers.py
    */list_current_incentives.py
    */list_current_offers.py

    # ── Ad-hoc test drivers (shell scripts, not pytest) ───────────────────────
    */test_ride_flow.py
    */test_driver_onboarding.py
    */test_script.py
    */test_urls.py

    # ── Test suite itself (measuring coverage OF tests is meaningless) ─────────
    */tests/*
    */tests/**/*

    # ── Django app boilerplate generated by startapp ──────────────────────────
    */apps/*/apps.py
    */apps/*/admin.py
    */apps/*/tests.py

    # ── Third-party & virtualenv ───────────────────────────────────────────────
    */venv/*
    */.venv/*
    */site-packages/*

[report]
# ── Display ───────────────────────────────────────────────────────────────────
# Skip files with 100% coverage to reduce noise in terminal output.
skip_covered = false

# Show lines and branches that were NOT executed.
show_missing = true

# Minimum coverage threshold — fail the build if below this value.
# Set to match your SonarQube Quality Gate target.
fail_under = 75

# Precision of the percentage shown in reports.
precision = 2

# ── Exclude specific lines / blocks from measurement ─────────────────────────
exclude_lines =
    # Standard "never reached" pragma
    pragma: no cover

    # Abstract method stubs
    raise NotImplementedError
    raise NotImplemented

    # Defensive programming / type guards
    if TYPE_CHECKING:
    if __name__ == .__main__.:

    # Protocol / Abstract class markers
    @(abc\.)?abstractmethod

    # Overload stubs
    @overload

[html]
# ── HTML Report ───────────────────────────────────────────────────────────────
directory = htmlcov
title = Uber Backend — Coverage Report

[xml]
# ── XML Report (consumed by SonarQube) ───────────────────────────────────────
output = coverage.xml
